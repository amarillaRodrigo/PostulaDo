# Copy this file to .env and fill with your local database credentials.
# Do NOT commit your real .env file to the repository.

# Example PostgreSQL connection (replace user, password, host, port, dbname):
DATABASE_URL="postgresql://user:password@localhost:5432/postulado_db?schema=public"

# Optionally a DIRECT_URL can be used by Prisma in some deployments
# DIRECT_URL="postgresql://user:password@host:port/postulado_db?schema=public"

# You can also use SQLite for quick local testing (alternative):
# DATABASE_URL="file:./dev.db"

# SGLang Inferencia
SGLANG_URL="http://localhost:30000/v1"
SGLANG_API_KEY="EMPTY"
