  "info": {
    "title": "Postulado API",
    "description": "API para la gestión de usuarios y postulaciones",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "PublicUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "9a1b2c3d-..."
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "example": "Rodrigo"
          },
          "role": {
            "type": "string",
            "example": "USER"
          },
          "birthDate": {
            "type": "string",
            "example": "1998-05-20T00:00:00.000Z"
          },
          "countryCode": {
            "type": "string",
            "example": "AR"
          },
          "createdAt": {
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "email",
          "birthDate",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateUsuarioDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "Secret123",
            "writeOnly": true
          },
          "name": {
            "type": "string",
            "example": "Rodrigo"
          },
          "birthDate": {
            "type": "string",
            "example": "1998-05-20"
          },
          "countryCode": {
            "type": "string",
            "example": "AR"
          }
        },
        "required": [
          "email",
          "password",
          "birthDate"
        ]
      },
      "UpdateUsuarioDto": {
        "type": "object",
        "properties": {}
      },
      "AnalyzePostulacionDto": {
        "type": "object",
        "properties": {}
      },
      "CreatePostulacionDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "example": "https://empresa.com/oferta/123"
          },
          "title": {
            "type": "string",
            "example": "Frontend Developer"
          },
          "description": {
            "type": "string",
            "example": "Fullstack role at ACME"
          }
        },
        "required": [
          "url"
        ]
      },
      "UpdatePostulacionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "New title"
          },
          "description": {
            "type": "string",
            "example": "Updated description"
          },
          "status": {
            "type": "string",
            "example": "ENTREVISTA"
          },
          "isArchived": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "AuthResultDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/PublicUserDto"
          }
        },
        "required": [
          "access_token",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "Secret123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
}